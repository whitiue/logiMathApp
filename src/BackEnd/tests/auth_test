from fastapi.testclient import TestClient
from src.BackEnd.mainApi import app

client = TestClient(app)

# Tests de REGISTRO
def test_register_success():
    """Registro exitoso debe retornar 201"""
    response = client.post("/register", json={
        "email": "newuser@example.com",
        "password": "securepass123"
    })
    assert response.status_code == 201
    assert "access_token" in response.json()


def test_register_invalid_email():
    """Email inválido debe retornar 400"""
    response = client.post("/register", json={
        "email": "notanemail",
        "password": "securepass123"
    })
    assert response.status_code == 400


def test_register_short_password():
    """Password muy corta debe retornar 400"""
    response = client.post("/register", json={
        "email": "user@example.com",
        "password": "123"
    })
    assert response.status_code == 400


def test_register_duplicate_email():
    """Registrar el mismo email dos veces debe fallar en el segundo"""
    email = "duplicate@example.com"
    
    # Primer registro exitoso
    response1 = client.post("/register", json={
        "email": email,
        "password": "securepass123"
    })
    assert response1.status_code == 201
    
    # Segundo registro con mismo email debe fallar
    response2 = client.post("/register", json={
        "email": email,
        "password": "securepass123"
    })
    assert response2.status_code == 400


# Tests de LOGIN
def test_login_success():
    """Login con credenciales correctas debe retornar 200 y token"""
    # Primero registra un usuario
    client.post("/register", json={
        "email": "logintest@example.com",
        "password": "securepass123"
    })
    
    # Luego intenta login
    response = client.post("/login", json={
        "email": "logintest@example.com",
        "password": "securepass123"
    })
    assert response.status_code == 200
    assert "access_token" in response.json()


def test_login_wrong_password():
    """Login con contraseña incorrecta debe retornar 401"""
    # Registra
    client.post("/register", json={
        "email": "wrongpass@example.com",
        "password": "securepass123"
    })
    
    # Intenta login con password mal
    response = client.post("/login", json={
        "email": "wrongpass@example.com",
        "password": "wrongpassword"
    })
    assert response.status_code == 401


def test_login_nonexistent_user():
    """Login con usuario que no existe debe retornar 401"""
    response = client.post("/login", json={
        "email": "doesnotexist@example.com",
        "password": "anypassword"
    })
    assert response.status_code == 401


# Tests de PROTECTED ROUTE (/me)
def test_me_with_valid_token():
    """GET /me con token válido debe retornar info del usuario"""
    # Registra y obtén token
    register_response = client.post("/register", json={
        "email": "metest@example.com",
        "password": "securepass123"
    })
    token = register_response.json()["access_token"]
    
    # Usa el token
    response = client.get("/me", headers={
        "Authorization": f"Bearer {token}"
    })
    assert response.status_code == 200
    assert response.json()["email"] == "metest@example.com"


def test_me_without_token():
    """GET /me sin token debe retornar 401"""
    response = client.get("/me")
    assert response.status_code == 401


def test_me_with_invalid_token():
    """GET /me con token inválido debe retornar 401"""
    response = client.get("/me", headers={
        "Authorization": "Bearer invalidtoken123"
    })
    assert response.status_code == 401